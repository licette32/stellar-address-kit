{
  "$schema": "http://json-schema.org/draft-07/schema",
  "definitions": {
    "warningNormalization": {
      "type": "object",
      "required": ["code", "severity", "message", "normalization"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "enum": ["NON_CANONICAL_ADDRESS", "NON_CANONICAL_ROUTING_ID"] },
        "severity": { "type": "string", "const": "warn" },
        "message": { "type": "string" },
        "normalization": {
          "type": "object",
          "required": ["original", "normalized"],
          "additionalProperties": false,
          "properties": {
            "original": { "type": "string" },
            "normalized": { "type": "string" }
          }
        }
      }
    },
    "warningInvalidDestination": {
      "type": "object",
      "required": ["code", "severity", "message", "context"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "const": "INVALID_DESTINATION" },
        "severity": { "type": "string", "const": "error" },
        "message": { "type": "string" },
        "context": {
          "type": "object",
          "required": ["destinationKind"],
          "additionalProperties": false,
          "properties": {
            "destinationKind": { "type": "string", "const": "C" }
          }
        }
      }
    },
    "warningUnsupportedMemoType": {
      "type": "object",
      "required": ["code", "severity", "message", "context"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "const": "UNSUPPORTED_MEMO_TYPE" },
        "severity": { "type": "string", "const": "warn" },
        "message": { "type": "string" },
        "context": {
          "type": "object",
          "required": ["memoType"],
          "additionalProperties": false,
          "properties": {
            "memoType": { "type": "string", "enum": ["hash", "return", "unknown"] }
          }
        }
      }
    },
    "warningGeneric": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "MEMO_IGNORED_FOR_MUXED", "MEMO_PRESENT_WITH_MUXED",
            "CONTRACT_SENDER_DETECTED", "MEMO_TEXT_UNROUTABLE",
            "MEMO_ID_INVALID_FORMAT"
          ]
        },
        "severity": { "type": "string", "enum": ["info", "warn", "error"] },
        "message": { "type": "string" }
      }
    },
    "warning": {
      "oneOf": [
        { "$ref": "#/definitions/warningNormalization" },
        { "$ref": "#/definitions/warningInvalidDestination" },
        { "$ref": "#/definitions/warningUnsupportedMemoType" },
        { "$ref": "#/definitions/warningGeneric" }
      ]
    }
  },
  "type": "object",
  "required": ["spec_version", "cases"],
  "properties": {
    "spec_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "description", "input", "expected", "tags"],
        "properties": {
          "module": {
            "type": "string",
            "enum": ["detect", "muxed_encode", "muxed_decode", "extract_routing"]
          },
          "description": { "type": "string" },
          "input": { "type": "object" },
          "expected": {
            "type": "object",
            "properties": {
              "warnings": {
                "type": "array",
                "items": { "$ref": "#/definitions/warning" }
              }
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "enum": ["positive", "negative", "edge", "interop", "regression", "scope-boundary"]
            }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
