{
  "name": "stellar-address-kit",
  "version": "1.0.0",
  "description": "TypeScript implementation of the Stellar Address Kit",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
